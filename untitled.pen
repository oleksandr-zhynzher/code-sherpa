                  "children": [
                    {
                      "type": "text",
                      "id": "cuF0D",
                      "name": "sherpaP1",
                      "fill": "$--foreground-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Learning to solve problems is a climb — and every climber needs a guide who knows the mountain. Code-sherpa walks beside you, offering hints when you're stuck, not handing you the summit.",
                      "lineHeight": 1.7,
                      "fontFamily": "$--font-body",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "RC6AT",
                      "name": "sherpaP2",
                      "fill": "$--foreground-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Unlike platforms that test and score, we focus on guided practice — building real understanding through exploration, not memorization. You learn to think, not just to pass.",
                      "lineHeight": 1.7,
                      "fontFamily": "$--font-body",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "CdWpT",
                      "name": "sherpaP3",
                      "fill": "$--foreground-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Every step is recorded. Every struggle becomes a lesson. And when you look back at how far you've come, you'll see the path was worth it.",
                      "lineHeight": 1.7,
                      "fontFamily": "$--font-body",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    }
                  ]
                },
