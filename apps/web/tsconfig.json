{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "composite": true,
    "emitDeclarationOnly": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "outDir": "../../dist/types/apps/web",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "rootDir": "."
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
