{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build apps/web"
      },
      "outputs": ["{workspaceRoot}/apps/web/.next"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev apps/web -p 3000"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint apps/web --ext .ts,.tsx --max-warnings=0"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start apps/web -p 3000 -H 0.0.0.0"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config apps/web/vitest.config.ts"
      }
    }
  }
}
